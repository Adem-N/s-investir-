# ─────────────────────────────────────────────────────────────
# CoinGecko Demo API key (gratuit) — pour le catalogue de cryptos,
# les logos et les prix actuels. https://www.coingecko.com/en/developers/dashboard
# Optionnel : sans clé, l'app retombe sur le catalogue + l'historique embarqués.
# ─────────────────────────────────────────────────────────────
COINGECKO_API_KEY=

# ─────────────────────────────────────────────────────────────
# Supabase (optionnel) — sauvegarde des simulations + auth.
# Laisser vide pour faire tourner la démo en mode anonyme.
# https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# URL publique du site (optionnel). Résolue automatiquement depuis
# l'environnement Vercel ; à ne renseigner que pour forcer un domaine
# (ex. domaine custom) ou en local. Sert aux images Open Graph.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
